# template.env — copy to .env and fill in. Used by BOTH forja_bootstrap.sh
# and forja_userspace.sh. This template itself is not read by the scripts.

# ======================== Bootstrap variables ========================
# disk
DISK=                   # target disk; leave empty to be prompted
BOOT_SIZE=1G
SWAP_SIZE=4G

# identity
HOSTNAME=forja
USER=template
ROOT_PASSWD=changeme
USER_PASSWD=changeme

# ======================== Userspace variables ========================
# packages
PACMAN_PACKAGES="zsh git nvim man-db man-pages stow ripgrep fd fzf bat tmux btop shellcheck openssh unzip tree jq base-devel starship zsh-syntax-highlighting"
AUR_HELPER="yay"
AUR_PACKAGES="cbonsai"

# dotfiles
DOTFILES_REPO=https://github.com/user/changeme
DOTFILES_DIR=$HOME/.dotfiles
STOW_PACKAGES="nvim"

# fonts (installed via pacman; the *_FONT names are for your app configs,
# not consumed by the script)
FONT_PACKAGES="ttf-jetbrains-mono-nerd noto-fonts noto-fonts-emoji ttf-dejavu"
FONT_EDITOR="JetBrainsMono Nerd Font"
FONT_TERMINAL="JetBrainsMono Nerd Font"
FONT_UI="Noto Sans"

# timezone / ntp / locale / keymap
# DEFAULT_KEYMAP names one of the flattened maps generated from
# utilities/keymaps/ (e.g. es-capsesc, us-capsesc). It's loaded live and
# written to /etc/vconsole.conf so it persists across boots.
LOCALE=en_US.UTF-8
DEFAULT_KEYMAP="es-capsesc"
TIMEZONE=Europe/Madrid
ENABLE_NTP=true

# graphics / wayland / bluetooth / shell
# GPU driver is auto-detected from lspci (no vendor variable).
# Sway launch-on-login is a dotfile, not set here.
# SETUP_ZSH_SHELL=true makes zsh the login shell (zsh must be in PACMAN_PACKAGES).
SETUP_GPU=true
SETUP_WAYLAND=true
SETUP_BLUETOOTH=true
SETUP_ZSH_SHELL=true
WAYLAND_PACKAGES="sway swaybg swaylock swayidle waybar wmenu ghostty mako grim slurp wl-clipboard cliphist xdg-desktop-portal xdg-desktop-portal-gtk xorg-xwayland"
